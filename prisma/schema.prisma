generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           Int       @id @default(autoincrement())
  username     String    @unique
  email        String    @unique
  passwordHash String
  role         UserRole
  isActive     Boolean   @default(true)
  fullName     String
}

enum UserRole {
  ADMIN
  USER
}
